@model CitasApp.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ingresar - CitasApp</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="auth-body">
    <main class="auth-shell">
        <section class="auth-panel">
            <div class="auth-brand">
                <div class="brand-mark">CR</div>
                <div>
                    <h1>CitasApp</h1>
                    <p>Acceso administrativo</p>
                </div>
            </div>

            <div class="auth-heading">
                <h2>Bienvenido</h2>
                <p>Ingresa para gestionar citas, pacientes y configuracion.</p>
            </div>

            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-success">@TempData["Mensaje"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-error">@TempData["Error"]</div>
            }

            <form asp-action="Login" method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="form-error"></div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Correo</label>
                    <input asp-for="Email" class="form-control" autocomplete="username" />
                    <span asp-validation-for="Email" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Contrasena</label>
                    <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Admin123" />
                    <span asp-validation-for="Password" class="form-error"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-block">Entrar</button>
            </form>

            <div class="auth-footer">
                <span>Admin inicial: admin@citasapp.local</span>
                <a asp-action="Register">Registrar administrador</a>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
